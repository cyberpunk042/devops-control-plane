/* ──────────────────────────────────────────────────────────
   DevOps Control Plane — Docusaurus Theme
   Indigo primary palette with dark mode support
   ────────────────────────────────────────────────────────── */

:root {
  --ifm-color-primary: #6366f1;
  --ifm-color-primary-dark: #4f46e5;
  --ifm-color-primary-darker: #4338ca;
  --ifm-color-primary-darkest: #3730a3;
  --ifm-color-primary-light: #818cf8;
  --ifm-color-primary-lighter: #a5b4fc;
  --ifm-color-primary-lightest: #c7d2fe;

  --ifm-code-font-size: 95%;
  --ifm-font-family-base: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;

  --docusaurus-highlighted-code-line-bg: rgba(0, 0, 0, 0.1);
}

[data-theme='dark'] {
  --ifm-color-primary: #818cf8;
  --ifm-color-primary-dark: #6366f1;
  --ifm-color-primary-darker: #4f46e5;
  --ifm-color-primary-darkest: #4338ca;
  --ifm-color-primary-light: #a5b4fc;
  --ifm-color-primary-lighter: #c7d2fe;
  --ifm-color-primary-lightest: #e0e7ff;

  --docusaurus-highlighted-code-line-bg: rgba(255, 255, 255, 0.08);
}

/* ── Typography ────────────────────────────────────────── */

article h1 {
  font-size: 2rem;
  font-weight: 700;
}

article h2 {
  border-bottom: 1px solid var(--ifm-color-emphasis-200);
  padding-bottom: 0.3rem;
}

/* ── Code blocks ───────────────────────────────────────── */

.theme-code-block {
  border: 1px solid var(--ifm-color-emphasis-200);
  border-radius: var(--ifm-code-border-radius);
}

[data-theme='dark'] .theme-code-block {
  border-color: var(--ifm-color-emphasis-300);
}

/* ── Admonitions ───────────────────────────────────────── */

.theme-admonition {
  border-radius: 8px;
}

/* ── Tables ────────────────────────────────────────────── */

table {
  display: table;
  width: 100%;
}

table th {
  background: var(--ifm-color-emphasis-100);
}

[data-theme='dark'] table th {
  background: var(--ifm-color-emphasis-200);
}

/* ── Sidebar ───────────────────────────────────────────── */

.menu__link--active:not(.menu__link--sublist) {
  background: rgba(99, 102, 241, 0.08);
}

[data-theme='dark'] .menu__link--active:not(.menu__link--sublist) {
  background: rgba(129, 140, 248, 0.12);
}

/* ── Search (when enabled) ─────────────────────────────── */

.navbar__search-input {
  background: var(--ifm-color-emphasis-100);
}

[data-theme='dark'] .navbar__search-input {
  background: var(--ifm-color-emphasis-200);
}

/* ── Footer ────────────────────────────────────────────── */

.footer--dark {
  background-color: #0f0f23;
}

/* ── Language Selector (Google Translate) ──────────────── */

.language-selector {
  position: relative;
  display: flex;
  align-items: center;
}

.language-selector-button {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  background: transparent;
  border: 1px solid var(--ifm-color-emphasis-300);
  border-radius: 6px;
  padding: 0.4rem 0.6rem;
  cursor: pointer;
  color: var(--ifm-navbar-link-color);
  font-size: 0.85rem;
  transition: all 0.2s ease;
}

.language-selector-button:hover {
  border-color: var(--ifm-color-primary);
  background: var(--ifm-color-emphasis-100);
}

.language-label {
  font-weight: 600;
  font-size: 0.85rem;
  min-width: 1.5rem;
}

.language-name {
  font-weight: 500;
}

.language-arrow {
  font-size: 0.6rem;
  opacity: 0.6;
}

.language-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  min-width: 160px;
  background: var(--ifm-background-surface-color);
  border: 1px solid var(--ifm-color-emphasis-200);
  border-radius: 8px;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  z-index: 1000;
  overflow: hidden;
  animation: dropdownSlide 0.15s ease;
}

@keyframes dropdownSlide {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.language-option {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  width: 100%;
  padding: 0.6rem 0.8rem;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--ifm-color-content);
  font-size: 0.9rem;
  text-align: left;
  transition: background 0.15s ease;
}

.language-option:hover {
  background: var(--ifm-color-emphasis-100);
}

.language-option.active {
  background: var(--ifm-color-primary-lightest);
  color: var(--ifm-color-primary-dark);
  font-weight: 600;
}

.language-notice {
  padding: 0.5rem 0.8rem;
  font-size: 0.75rem;
  color: var(--ifm-color-content-secondary);
  border-top: 1px solid var(--ifm-color-emphasis-200);
  text-align: center;
}

/* Prevent Google Translate from modifying navbar elements */
.navbar__title,
.navbar__brand,
.hash-link,
code,
pre {
  translate: no;
}

/* Fix Google Translate visual artifacts */
font[style] {
  background: transparent !important;
}

/* Hide Google Translate visual elements but keep functionality */
.skiptranslate,
.goog-te-banner-frame {
  display: none !important;
}

body { top: 0 !important; }

#google_translate_hidden {
  position: absolute;
  left: -9999px;
  visibility: hidden;
}

.navbar__items--right>.navbar__item:has(#navbar-language-selector) {
  display: flex;
  align-items: center;
  padding: 0;
}

#navbar-language-selector {
  display: flex;
  align-items: center;
}

/* Hide content until translation completes */
html.translation-active main { opacity: 0; transition: opacity 0.2s ease; }
html.translation-ready main { opacity: 1; }

@keyframes bounce-dot {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.6; }
  40% { transform: translateY(-12px); opacity: 1; }
}

/* Container loading state during translation (SPA navigation) */
[class*="docMainContainer"].translating,
main.translating {
  position: relative;
  min-height: 300px;
}

[class*="docMainContainer"].translating > *,
main.translating > * {
  visibility: hidden;
}

[class*="docMainContainer"].translating::after,
main.translating::after {
  content: '• • •';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 2.5rem;
  letter-spacing: 0.5rem;
  color: var(--ifm-color-primary);
  animation: bounce-dot 1.4s ease-in-out infinite;
}

/* Loading overlay for translation */
.translation-loading-dots {
  font-size: 2.5rem;
  letter-spacing: 0.5rem;
  color: var(--ifm-color-primary);
  animation: bounce-dot 1.4s ease-in-out infinite;
}

/* Mobile responsive */
@media (max-width: 996px) {
  .language-selector-button {
    padding: 0.3rem 0.5rem;
    font-size: 0.8rem;
  }
  .language-label { font-size: 0.8rem; }
  .language-arrow { font-size: 0.5rem; }
  .language-dropdown {
    position: fixed;
    top: 60px;
    right: 10px;
    max-width: calc(100vw - 20px);
  }
}

/* ── Peek links (auto-linked file references) ─────────── */

.peek-link {
  color: inherit;
  text-decoration: none;
  border-bottom: 1px dotted rgba(129, 140, 248, 0.4);
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}

.peek-link:hover {
  color: var(--ifm-color-primary) !important;
  border-bottom-color: var(--ifm-color-primary);
  border-bottom-style: solid;
}

code .peek-link,
.peek-link code {
  color: inherit;
  border-bottom: 1px dotted rgba(129, 140, 248, 0.3);
}

code .peek-link:hover,
.peek-link code:hover {
  color: var(--ifm-color-primary) !important;
}

pre .peek-link {
  border-bottom: none;
  text-decoration: underline;
  text-decoration-style: dotted;
  text-decoration-color: rgba(129, 140, 248, 0.35);
  text-underline-offset: 2px;
}

pre .peek-link:hover {
  text-decoration-color: var(--ifm-color-primary);
  text-decoration-style: solid;
}

/* Directory peek links */
.peek-link--directory {
  border-bottom-color: rgba(129, 199, 132, 0.4);
}
.peek-link--directory:hover {
  color: #81c784 !important;
  border-bottom-color: #81c784;
}

/* Unresolved peek links */
.peek-link--unresolved {
  border-bottom-color: rgba(255, 183, 77, 0.3);
  opacity: 0.7;
}
.peek-link--unresolved:hover {
  color: #ffb74d !important;
  border-bottom-color: #ffb74d;
  opacity: 1;
}

/* ── Pending annotation (pulsing "Resolving…" state) ── */
.peek-link--pending {
  border-bottom: 1px dotted rgba(144, 202, 249, 0.4);
  opacity: 0.6;
  animation: peekPendingPulse 1.5s ease-in-out infinite;
}
.peek-link--pending:hover {
  color: #90caf9 !important;
  border-bottom-color: #90caf9;
  opacity: 1;
}
@keyframes peekPendingPulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* ── Peek tooltip ─────────────────────────────────────── */

.peek-tooltip {
  position: fixed;
  z-index: 10000;
  min-width: 260px;
  max-width: 480px;
  background: rgba(30, 30, 36, 0.96);
  border: 1px solid rgba(129, 140, 248, 0.25);
  border-radius: 8px;
  padding: 10px 14px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45), 0 2px 8px rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(12px);
  font-size: 13px;
  color: #e0e0e0;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.peek-tooltip__header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}

.peek-tooltip__icon {
  font-size: 14px;
  flex-shrink: 0;
}

.peek-tooltip__path {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 12px;
  color: #90caf9;
  word-break: break-all;
  flex: 1;
  min-width: 0;
}

.peek-tooltip__close {
  background: none;
  border: none;
  color: #999;
  cursor: pointer;
  font-size: 14px;
  padding: 0 2px;
  line-height: 1;
  flex-shrink: 0;
  transition: color 0.15s;
}
.peek-tooltip__close:hover {
  color: #fff;
}

.peek-tooltip__label {
  font-size: 11px;
  color: #888;
  margin-bottom: 8px;
}

.peek-tooltip__info {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
}

.peek-tooltip__tag {
  display: inline-block;
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 10px;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  background: rgba(129, 140, 248, 0.12);
  color: var(--ifm-color-primary);
  border: 1px solid rgba(129, 140, 248, 0.2);
  flex-shrink: 0;
}

.peek-tooltip__tag--dir {
  background: rgba(255, 183, 77, 0.12);
  color: #ffb74d;
  border-color: rgba(255, 183, 77, 0.2);
}

.peek-tooltip__context {
  font-size: 11px;
  color: #888;
}


.peek-tooltip__outline {
  margin: 6px 0 8px 0;
  padding: 4px 0 4px 10px;
  border-left: 2px solid rgba(129, 140, 248, 0.2);
  max-height: 120px;
  overflow-y: auto;
}

.peek-tooltip__outline-item {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 11px;
  color: #aaa;
  line-height: 1.6;
  white-space: pre;
}

.peek-tooltip__outline-item--link {
  display: block;
  text-decoration: none;
  color: #aaa;
  border-radius: 3px;
  padding: 0 4px;
  cursor: pointer;
  transition: color 0.12s, background 0.12s;
}

.peek-tooltip__outline-item--link:hover {
  color: var(--ifm-color-primary-light, #a5b4fc);
  background: rgba(129, 140, 248, 0.08);
  text-decoration: none;
}

.peek-tooltip__actions {
  display: flex;
  gap: 8px;
}

.peek-tooltip__btn {
  display: inline-block;
  padding: 4px 14px;
  border-radius: 4px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.06);
  color: #ccc;
  font-size: 12px;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.peek-tooltip__btn:hover {
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  border-color: rgba(255, 255, 255, 0.2);
  text-decoration: none;
}

.peek-tooltip__btn--primary {
  background: rgba(129, 140, 248, 0.15);
  color: var(--ifm-color-primary);
  border-color: rgba(129, 140, 248, 0.3);
}
.peek-tooltip__btn--primary:hover {
  background: rgba(129, 140, 248, 0.25);
  color: var(--ifm-color-primary-lightest);
  border-color: rgba(129, 140, 248, 0.5);
}

/* ── Peek preview overlay ─────────────────────────────── */

.peek-preview-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10001;
  animation: dropdownSlide 0.2s ease;
  padding: 1.5rem;
}

.peek-preview-box {
  background: var(--ifm-background-surface-color);
  border: 1px solid var(--ifm-color-emphasis-200);
  border-radius: 12px;
  width: 100%;
  max-width: 85vw;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 16px 64px rgba(0, 0, 0, 0.5);
}

.peek-preview-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  border-bottom: 1px solid var(--ifm-color-emphasis-200);
  flex-shrink: 0;
}

.peek-preview-header__icon {
  font-size: 1.1rem;
}

.peek-preview-header__path {
  flex: 1;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 0.82rem;
  color: var(--ifm-color-content-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.peek-preview-header__line {
  font-size: 0.75rem;
  color: var(--ifm-color-primary);
  background: rgba(129, 140, 248, 0.1);
  border: 1px solid rgba(129, 140, 248, 0.25);
  border-radius: 4px;
  padding: 0.1rem 0.4rem;
}

.peek-preview-header__close {
  background: none;
  border: none;
  color: var(--ifm-color-content-secondary);
  font-size: 1.1rem;
  cursor: pointer;
  padding: 0.2rem 0.4rem;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
}

.peek-preview-header__close:hover {
  color: var(--ifm-color-content);
  background: var(--ifm-color-emphasis-100);
}

.peek-preview-header__action {
  font-size: 0.75rem;
  padding: 0.2rem 0.55rem;
  border-radius: 4px;
  border: 1px solid rgba(129, 140, 248, 0.25);
  background: rgba(129, 140, 248, 0.08);
  color: var(--ifm-color-primary);
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
  white-space: nowrap;
}

.peek-preview-header__action:hover {
  background: rgba(129, 140, 248, 0.18);
  color: var(--ifm-color-primary-light);
  border-color: rgba(129, 140, 248, 0.4);
  text-decoration: none;
}

.peek-preview-body {
  flex: 1 1 auto;
  overflow: auto;
  min-height: 0;
  padding: 1rem;
}

.peek-preview-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3rem;
  color: var(--ifm-color-content-secondary);
  gap: 0.5rem;
}

/* ── Loading spinner ── */
.peek-spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.15);
  border-top-color: var(--ifm-color-primary);
  border-radius: 50%;
  animation: peekSpin 0.8s linear infinite;
}

@keyframes peekSpin {
  to { transform: rotate(360deg); }
}

/* ── Directory preview tabs ── */
.peek-dir-tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--ifm-color-emphasis-200);
  padding: 0 0.5rem;
  margin-bottom: 0;
}

.peek-dir-tab {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 0.5rem 1rem;
  font-size: 0.82rem;
  color: var(--ifm-color-content-secondary);
  cursor: pointer;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}

.peek-dir-tab:hover {
  color: var(--ifm-color-content);
}

.peek-dir-tab.active {
  color: var(--ifm-color-primary);
  border-bottom-color: var(--ifm-color-primary);
}

.peek-dir-content {
  padding: 0.75rem 1rem;
  overflow: auto;
}

/* ── Directory listing items ── */
.peek-listing-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 0.5rem;
  border-radius: 4px;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 0.82rem;
  transition: background 0.12s;
}

.peek-listing-item:hover {
  background: var(--ifm-color-emphasis-100);
}

/* ── Outline row action buttons ── */
.peek-tooltip__outline-row {
  border-radius: 3px;
  transition: background 0.12s;
}
.peek-tooltip__outline-row:hover {
  background: rgba(129, 140, 248, 0.06);
}

.peek-tooltip__outline-actions {
  opacity: 0;
  transition: opacity 0.12s;
}
.peek-tooltip__outline-row:hover .peek-tooltip__outline-actions {
  opacity: 1;
}

.peek-outline-act {
  background: none;
  border: 1px solid transparent;
  color: #888;
  font-size: 10px;
  cursor: pointer;
  padding: 0 3px;
  border-radius: 3px;
  line-height: 1.4;
  transition: color 0.12s, background 0.12s, border-color 0.12s;
}
.peek-outline-act:hover {
  color: #fff;
  background: rgba(129, 140, 248, 0.15);
  border-color: rgba(129, 140, 248, 0.3);
}

/* ── Heading tracking highlight ── */
.peek-heading-tracked {
  background: rgba(100, 181, 246, 0.08) !important;
  border-left: 2px solid rgba(100, 181, 246, 0.5);
  padding-left: 0.5rem;
  transition: background 0.3s;
}

/* ── Preview header line badge ── */
.peek-preview-header__line {
  font-size: 0.72rem;
  color: var(--ifm-color-primary);
  background: rgba(129, 140, 248, 0.1);
  padding: 1px 6px;
  border-radius: 3px;
  font-family: monospace;
  min-width: 2rem;
  text-align: center;
}

/* ── Annotation count badge ── */
.peek-status {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.35rem 0.75rem;
  background: var(--ifm-background-surface-color);
  border: 1px solid var(--ifm-color-emphasis-200);
  border-radius: 20px;
  font-size: 0.78rem;
  color: var(--ifm-color-content-secondary);
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  z-index: 999;
  animation: peekStatusIn 0.3s ease;
  transition: opacity 0.6s ease;
}

.peek-status--subtle {
  opacity: 0.4;
}

.peek-status:hover {
  opacity: 1;
}

.peek-status__icon {
  font-size: 0.85rem;
}

.peek-status__count {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
}

@keyframes peekStatusIn {
  from { transform: translateY(10px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* ── Dev/Live mode toggle badge (in navbar, matches admin panel .dev-badge) ── */
.peek-mode-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  background: hsla(260, 60%, 55%, 0.15);
  color: hsl(260, 70%, 70%);
  border: 1px solid hsla(260, 60%, 55%, 0.25);
  cursor: pointer;
  transition: background 0.15s ease, border-color 0.15s ease;
  user-select: none;
}
.peek-mode-badge:hover {
  background: hsla(260, 60%, 55%, 0.25);
  border-color: hsla(260, 60%, 55%, 0.4);
}
.peek-mode-badge__icon {
  font-size: 0.85rem;
}
.peek-mode-badge__label {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-weight: 700;
}

